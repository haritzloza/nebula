# Forzar line endings LF (Unix) en TODOS los archivos.
# Critico para un repo de dotfiles desplegado en Linux: CRLF rompe shebangs
# de bash, zsh, python; rompe configs de Hyprland/waybar; rompe matugen.

* text=auto eol=lf

# Binarios — no tocar
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.db   binary
*.sqlite  binary
*.sqlite3 binary

# Forzar LF explícito en scripts (defensa en profundidad)
*.sh   text eol=lf
*.bash text eol=lf
*.zsh  text eol=lf

# Archivos de Linux que no deben usar CRLF
*.conf      text eol=lf
*.toml      text eol=lf
*.rasi      text eol=lf
*.css       text eol=lf
*.lua       text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.profile   text eol=lf
.zshrc      text eol=lf
.zprofile   text eol=lf
.bashrc     text eol=lf
