{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "claude-sonnet-4-6",
    "theme": "dark",
    "autoCompactEnabled": true,
    "verbose": false,
    "permissions": {
        "allow": [
            "Bash(git status:*)",
            "Bash(git diff:*)",
            "Bash(git log:*)",
            "Bash(git branch:*)",
            "Bash(git show:*)",
            "Bash(ls:*)",
            "Bash(eza:*)",
            "Bash(cat:*)",
            "Bash(bat:*)",
            "Bash(rg:*)",
            "Bash(fd:*)",
            "Bash(find:*)",
            "Bash(which:*)",
            "Bash(echo:*)",
            "Bash(pwd)",
            "Bash(systemctl status:*)",
            "Bash(journalctl:*)",
            "Bash(docker ps:*)",
            "Bash(docker logs:*)",
            "Bash(docker compose ps:*)",
            "Bash(kubectl get:*)",
            "Bash(kubectl describe:*)",
            "Read(*)",
            "Glob(*)",
            "Grep(*)"
        ],
        "deny": [
            "Bash(rm -rf /*)",
            "Bash(sudo rm:*)",
            "Bash(dd:*)",
            "Bash(mkfs:*)",
            "Bash(:(){ :|:& };:)",
            "Read(**/.env)",
            "Read(**/.env.*)",
            "Read(**/credentials*)",
            "Read(**/.ssh/id_*)",
            "Read(**/.aws/credentials)",
            "Read(**/.kube/config)"
        ]
    },
    "hooks": {
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    { "type": "command", "command": "notify-send -t 4000 -i applications-development 'Claude' 'Tarea completada'" }
                ]
            }
        ]
    },
    "env": {
        "EDITOR": "nvim",
        "PAGER": "less -R"
    }
}
